.container {
  min-height: 100vh;
  padding: 60rpx 40rpx;
  background-color: #1f1f1f;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: #e8e8e8;
}

.header {
  margin-top: 100rpx;
  display: flex;
  flex-direction: column;
}

.logo-mark {
  width: 60rpx;
  height: 60rpx;
  background-color: #8fbc8f; /* Sage Green */
  border-radius: 50%;
  margin-bottom: 40rpx;
  position: relative;
}

.logo-mark::after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 30rpx;
  height: 30rpx;
  background-color: #1f1f1f;
  border-radius: 50%;
}

.title {
  font-size: 64rpx;
  font-weight: 300; /* Lighter weight for elegance */
  letter-spacing: 4rpx;
  margin-bottom: 24rpx;
  color: #ffffff;
}

.subtitle {
  font-size: 28rpx;
  color: #888888;
  letter-spacing: 2rpx;
  font-weight: 300;
}

.menu {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.card {
  background: #2a2a2a;
  border-radius: 4rpx; /* Sharper corners for modern/stone look */
  padding: 48rpx 50rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: all 0.3s ease;
  border-left: 6rpx solid #8fbc8f; /* Accent line */
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
}

.card:active {
  transform: scale(0.98);
  background: #333333;
}

.card-content {
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.card-desc {
  font-size: 24rpx;
  color: #999999;
}

.card-action {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 1px solid #444;
  margin-left: 70rpx;
}

.arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 2px solid #e8e8e8;
  border-right: 2px solid #e8e8e8;
  transform: rotate(45deg);
  margin-left: -4rpx;
}

.footer {
  text-align: center;
  padding-bottom: 40rpx;
}

.footer text {
  font-size: 20rpx;
  color: #444444;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}
