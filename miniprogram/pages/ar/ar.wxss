page {
  width: 100%;
  height: 100%;
}

.page-container {
  position: relative;
  width: 100%;
  height: 100%;
}

/* ===== 底部统一容器 ===== */
.bottom-area {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
}

/* ===== 弹幕输入栏 ===== */
.danmaku-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(30, 30, 30, 0.85);
  backdrop-filter: blur(12px);
}

/* GPS 状态圆点 */
.gps-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
  transition: background 0.3s;
}

.gps-dot.gps-ok {
  background: #00e676;
  box-shadow: 0 0 8rpx rgba(0, 230, 118, 0.6);
}

.gps-dot.gps-fail {
  background: #ff1744;
  box-shadow: 0 0 8rpx rgba(255, 23, 68, 0.6);
}

/* 弹幕输入框 */
.danmaku-input {
  flex: 1;
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.12);
  color: #fff;
  font-size: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.danmaku-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
}

/* 发送按钮 */
.danmaku-send {
  width: 72rpx;
  height: 64rpx;
  margin-left: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  opacity: 0.35;
  transition: opacity 0.2s;
}

.danmaku-send.active {
  opacity: 1;
}

.danmaku-send:active {
  transform: scale(0.9);
}

.send-icon {
  width: 48rpx;
  height: 48rpx;
}

/* 分隔线 */
.bar-divider {
  width: 2rpx;
  height: 36rpx;
  margin: 0 12rpx;
  background: rgba(255, 255, 255, 0.18);
  flex-shrink: 0;
}

/* 弹幕栏内的店铺切换按钮 */
.shop-toggle {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 50%;
  transition: background 0.2s;
}
.shop-toggle.shop-toggle-on {
  background: rgba(255, 255, 255, 0.15);
}
.shop-toggle:active {
  transform: scale(0.88);
}
.shop-toggle-icon {
  width: 40rpx;
  height: 40rpx;
}

/* ===== 店铺卡片滚动区 ===== */
.shop-scroll {
  width: 100%;
  white-space: nowrap;
  padding: 16rpx 24rpx;
  box-sizing: border-box;
}

.shop-loading {
  display: inline-block;
  color: rgba(255, 255, 255, 0.5);
  font-size: 26rpx;
  padding: 32rpx;
}

/* ===== 店铺卡片（横向布局） ===== */
.shop-card {
  display: inline-flex;
  flex-direction: row;
  width: 520rpx;
  margin-right: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  vertical-align: top;
  background: rgba(30, 30, 30, 0.65);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
}
.shop-card:last-child {
  margin-right: 0;
}

.shop-card-img {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  border-radius: 16rpx;
}

.shop-card-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 8rpx 16rpx 8rpx 20rpx;
  white-space: normal;
  min-width: 0;
}

.shop-card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.shop-card-desc {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
  line-height: 1.4;
  flex: 1;
}

.shop-card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.shop-card-dist {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.shop-checkin-btn {
  text-align: center;
  font-size: 22rpx;
  border-radius: 24rpx;
  padding: 8rpx 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.shop-checkin-btn.active {
  background: #00e676;
  color: #1a1a1a;
}
.shop-checkin-btn.disabled {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.35);
}
.shop-checkin-btn.active:active {
  opacity: 0.8;
}

/* ===== 打卡弹窗 ===== */
.checkin-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  background: rgba(0, 0, 0, 0.65);
  display: flex;
  align-items: center;
  justify-content: center;
}
.checkin-modal {
  width: 600rpx;
  background: #222;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.checkin-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 28rpx;
}
.checkin-modal-img {
  width: 520rpx;
  height: 520rpx;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  background: rgba(255, 255, 255, 0.05);
}
.checkin-modal-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
}
.checkin-save-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 40rpx;
  background: #00e676;
  color: #1a1a1a;
  font-size: 28rpx;
  font-weight: 600;
}
.checkin-save-btn:active {
  opacity: 0.8;
}
.checkin-close-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.12);
  color: #fff;
  font-size: 28rpx;
}
.checkin-close-btn:active {
  opacity: 0.7;
}
