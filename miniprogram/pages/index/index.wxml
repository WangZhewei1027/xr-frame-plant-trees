<view class="container">
  <view class="header">
    <view class="logo-mark"></view>
    <block wx:if="{{loaded}}">
      <text class="title">{{title || '无组织名'}}</text>
      <text class="subtitle" wx:if="{{subtitle}}">{{subtitle}}</text>
    </block>
    <block wx:else>
      <view class="skeleton skeleton-title"></view>
      <view class="skeleton skeleton-subtitle"></view>
    </block>

    <view class="switcher" wx:if="{{loaded && history.length > 1}}">
      <view class="switcher-trigger" bindtap="toggleDropdown">
        <text class="switcher-label">切换组织 / 空间</text>
        <view class="switcher-arrow {{dropdownOpen ? 'open' : ''}}"></view>
      </view>
      <view class="dropdown" wx:if="{{dropdownOpen}}">
        <view
          wx:for="{{history}}"
          wx:key="ts"
          class="dropdown-item {{item.active ? 'active' : ''}}"
          data-org="{{item.organizationId}}"
          data-ws="{{item.workspaceId}}"
          bindtap="onSelectHistory"
        >
          <text class="dropdown-text">{{item.label}}</text>
          <view class="dropdown-check" wx:if="{{item.active}}"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="menu">
    <view class="card" bindtap="goToAR">
      <view class="card-content">
        <text class="card-title">开启旅程</text>
        <text class="card-desc">探索 AR 景观与互动体验</text>
      </view>
      <view class="card-action">
        <view class="arrow"></view>
      </view>
    </view>
  </view>

  <view class="footer" wx:if="{{showFooter}}">
    <image class="footer-logo" src="/assets/DHL-Outlined.png" mode="aspectFit" />
  </view>
</view>
