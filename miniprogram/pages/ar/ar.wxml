<view class="page-container">
  <!-- AR 底层画布 -->
  <xr-start
    disable-scroll
    id="main-frame"
    width="{{renderWidth}}"
    height="{{renderHeight}}"
    style="width:{{width}}px;height:{{height}}px;"
    bind:orgconfigload="onOrgConfigLoad"
  />

  <!-- ===== 底部区域 ===== -->
  <view class="bottom-area">

    <!-- 店铺打卡组件（导航覆层 + 打卡弹窗 + 店铺列表） -->
    <block wx:if="{{shopCheckinEnabled}}">
      <shop-checkin
        id="shop-checkin"
        visible="{{showShopPanel}}"
        location="{{location}}"
        compass-heading="{{compassHeading}}"
        bind:navchange="onShopNavChange"
      />
    </block>

    <!-- 弹幕输入栏（始终可见） -->
    <view class="danmaku-bar">
      <view class="gps-dot {{location ? 'gps-ok' : 'gps-fail'}}"></view>
      <input
        class="danmaku-input"
        placeholder="发个弹幕到AR世界~"
        value="{{textContent}}"
        bindinput="onTextInput"
        maxlength="200"
        confirm-type="send"
        bindconfirm="submitText"
      />
      <view
        class="danmaku-send {{canSubmit ? 'active' : ''}}"
        bindtap="submitText"
      >
        <image class="send-icon" src="/assets/send.svg" mode="aspectFit" />
      </view>
      <view wx:if="{{shopCheckinEnabled}}" class="bar-divider"></view>
      <view wx:if="{{shopCheckinEnabled}}" class="shop-toggle {{showShopPanel ? 'shop-toggle-on' : ''}}" bindtap="toggleShopPanel">
        <image class="shop-toggle-icon" src="/assets/circle-check-big.svg" mode="aspectFit" />
      </view>
    </view>

  </view>
</view>
