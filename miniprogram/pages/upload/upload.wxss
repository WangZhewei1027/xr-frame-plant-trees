page {
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.container {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.header {
  text-align: center;
  padding: 48rpx 0 40rpx;
  flex-shrink: 0;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.form {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  flex: 1;
  display: flex;
  flex-direction: column;
}

.input-group {
  margin-bottom: 32rpx;
  flex-shrink: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #fafafa;
  line-height: 1.5;
}

.textarea:focus {
  border-color: #667eea;
  background: #fff;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.location-info {
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
  flex-shrink: 0;
}

.location-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.location-text {
  display: block;
  font-size: 22rpx;
  color: #333;
  font-family: -apple-system, monospace;
  line-height: 1.6;
}

.btn-group {
  margin-top: auto;
  padding-top: 24rpx;
}

.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
  border: none;
  text-align: center;
}

.btn::after {
  border: none;
}

.btn-location {
  background: #f0f0f0;
  color: #333;
}

.btn-location:active {
  background: #e5e5e5;
}

.btn-submit {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.btn-submit:active {
  opacity: 0.9;
}

.btn-submit[disabled] {
  background: #ccc;
  color: #999;
}

.back-link {
  text-align: center;
  padding: 32rpx 0;
  flex-shrink: 0;
}

.back-link text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.back-link text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}
