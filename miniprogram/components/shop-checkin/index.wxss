/* ===== 店铺卡片 Swiper ===== */
.shop-swiper-wrap {
  width: 100%;
  padding: 12rpx 0;
}

.shop-swiper {
  width: 100%;
  height: 200rpx;
}

.shop-loading {
  color: rgba(255, 255, 255, 0.5);
  font-size: 26rpx;
  padding: 32rpx 40rpx;
}

/* ===== 店铺卡片（横向布局） ===== */
.shop-card {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  margin: 0 12rpx;
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: rgba(30, 30, 30, 0.65);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  transition:
    box-shadow 0.3s,
    transform 0.3s;
  transform: scale(0.9);
  box-sizing: border-box;
}
.shop-card.selected {
  box-shadow:
    0 0 24rpx rgba(255, 255, 255, 0.4),
    0 4rpx 20rpx rgba(0, 0, 0, 0.3);
  transform: scale(1);
}

.shop-card-img {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  border-radius: 16rpx 0 0 16rpx;
}

.shop-card-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 12rpx 16rpx 12rpx 20rpx;
  white-space: normal;
  min-width: 0;
  overflow: hidden;
}

.shop-card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.shop-card-desc {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
  line-height: 1.4;
  flex: 1;
}

.shop-card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.shop-card-dist {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.shop-checkin-btn {
  text-align: center;
  font-size: 22rpx;
  border-radius: 24rpx;
  padding: 8rpx 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.shop-checkin-btn.active {
  background: #00e676;
  color: #1a1a1a;
}
.shop-checkin-btn.disabled {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.35);
}
.shop-checkin-btn.checked-in {
  background: rgba(0, 230, 118, 0.18);
  color: #00e676;
  border: 1rpx solid rgba(0, 230, 118, 0.4);
}
.shop-checkin-btn.checked-in:active {
  opacity: 0.8;
}
.shop-checkin-btn.active:active {
  opacity: 0.8;
}

/* ===== 打卡弹窗 ===== */
.checkin-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  background: rgba(0, 0, 0, 0.65);
  display: flex;
  align-items: center;
  justify-content: center;
}
.checkin-modal {
  width: 600rpx;
  background: #222;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.checkin-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 28rpx;
}
.checkin-modal-img {
  width: 520rpx;
  height: 520rpx;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  background: rgba(255, 255, 255, 0.05);
}
.checkin-modal-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
}
.checkin-save-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 40rpx;
  background: #00e676;
  color: #1a1a1a;
  font-size: 28rpx;
  font-weight: 600;
}
.checkin-save-btn:active {
  opacity: 0.8;
}
.checkin-close-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.12);
  color: #fff;
  font-size: 28rpx;
}
.checkin-close-btn:active {
  opacity: 0.7;
}

/* ===== 导航方向覆层 ===== */
.nav-overlay {
  position: fixed;
  top: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 90;
  pointer-events: none;
}

.nav-compass-ring {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(0, 210, 255, 0.55);
  background: rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 0 20rpx rgba(0, 210, 255, 0.4),
    inset 0 0 12rpx rgba(0, 210, 255, 0.1);
}

.nav-arrow-wrap {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s ease-out;
}

.nav-arrow-head {
  width: 0;
  height: 0;
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-bottom: 28rpx solid #00d2ff;
  filter: drop-shadow(0 0 6rpx rgba(0, 210, 255, 0.9));
}

.nav-arrow-tail {
  width: 6rpx;
  height: 18rpx;
  background: #00d2ff;
  border-radius: 0 0 4rpx 4rpx;
  opacity: 0.7;
}

.nav-info-row {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(0, 0, 0, 0.45);
  backdrop-filter: blur(8px);
  border-radius: 32rpx;
  padding: 8rpx 28rpx;
  border: 1rpx solid rgba(0, 210, 255, 0.3);
}

.nav-shop-name {
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.nav-dist {
  color: #00d2ff;
  font-size: 22rpx;
  margin-top: 4rpx;
}
