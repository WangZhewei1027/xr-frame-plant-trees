page {
  width: 100%;
  height: 100%;
}

.page-container {
  position: relative;
  width: 100%;
  height: 100%;
}

/* ===== 底部弹幕输入栏（Bilibili 风格） ===== */
.danmaku-bar {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(30, 30, 30, 0.85);
  backdrop-filter: blur(12px);
}

/* GPS 状态圆点 */
.gps-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
  transition: background 0.3s;
}

.gps-dot.gps-ok {
  background: #00e676;
  box-shadow: 0 0 8rpx rgba(0, 230, 118, 0.6);
}

.gps-dot.gps-fail {
  background: #ff1744;
  box-shadow: 0 0 8rpx rgba(255, 23, 68, 0.6);
}

/* 弹幕输入框 */
.danmaku-input {
  flex: 1;
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.12);
  color: #fff;
  font-size: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.danmaku-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
}

/* 发送按钮 */
.danmaku-send {
  width: 72rpx;
  height: 64rpx;
  margin-left: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  opacity: 0.35;
  transition: opacity 0.2s;
}

.danmaku-send.active {
  opacity: 1;
}

.danmaku-send:active {
  transform: scale(0.9);
}

.send-icon {
  width: 48rpx;
  height: 48rpx;
}
