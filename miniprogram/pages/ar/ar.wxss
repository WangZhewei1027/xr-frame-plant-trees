page {
  width: 100%;
  height: 100%;
}

.page-container {
  position: relative;
  width: 100%;
  height: 100%;
}

/* ===== 顶部 Logo 叠层 ===== */
.ar-top-logo {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 500rpx;
  height: 500rpx;
  z-index: 100;
  pointer-events: none;
}

/* ===== 底部统一容器 ===== */
.bottom-area {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
}

/* ===== 弹幕输入栏 ===== */
.danmaku-bar {
  position: relative;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  /* 不用 backdrop-filter: blur —— 实时背景模糊迫使合成器每帧重采样 AR 画布，持续吃 GPU */
  background: rgba(30, 30, 30, 0.85);
}

/* GPS 状态圆点（外层扩大点击区域，负 margin 抵消不影响布局） */
.gps-dot-tap {
  padding: 16rpx;
  margin: -16rpx 0 -16rpx -16rpx;
  flex-shrink: 0;
}

.gps-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  transition: background 0.3s;
}

/* GPS 调试小窗 */
.gps-debug-pop {
  position: absolute;
  left: 16rpx;
  bottom: calc(100% + 12rpx);
  padding: 14rpx 20rpx;
  border-radius: 12rpx;
  background: rgba(20, 20, 20, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  z-index: 10;
}

.gps-debug-row {
  font-size: 22rpx;
  line-height: 34rpx;
  color: #fff;
  white-space: nowrap;
}

.gps-debug-label {
  color: rgba(255, 255, 255, 0.5);
  margin-right: 12rpx;
}

.gps-dot.gps-ok {
  background: #00e676;
  box-shadow: 0 0 8rpx rgba(0, 230, 118, 0.6);
}

.gps-dot.gps-fail {
  background: #ff1744;
  box-shadow: 0 0 8rpx rgba(255, 23, 68, 0.6);
}

/* 弹幕输入框 */
.danmaku-input {
  flex: 1;
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.12);
  color: #fff;
  font-size: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.danmaku-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
}

/* 发送按钮 */
.danmaku-send {
  width: 72rpx;
  height: 64rpx;
  margin-left: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  opacity: 0.35;
  transition: opacity 0.2s;
}

.danmaku-send.active {
  opacity: 1;
}

.danmaku-send:active {
  transform: scale(0.9);
}

.send-icon {
  width: 48rpx;
  height: 48rpx;
}

/* 分隔线 */
.bar-divider {
  width: 2rpx;
  height: 36rpx;
  margin: 0 12rpx;
  background: rgba(255, 255, 255, 0.18);
  flex-shrink: 0;
}

/* 弹幕栏内的店铺切换按钮 */
.shop-toggle {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 50%;
  transition: background 0.2s;
}
.shop-toggle.shop-toggle-on {
  background: rgba(255, 255, 255, 0.15);
}
.shop-toggle:active {
  transform: scale(0.88);
}
.shop-toggle-icon {
  width: 40rpx;
  height: 40rpx;
}
